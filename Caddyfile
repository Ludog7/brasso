# Reverse proxy + TLS automatique (Let's Encrypt) pour le déploiement prod.
# Les variables sont injectées par docker-compose.yml.

{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode gzip zstd

	# En-têtes de sécurité de base
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# API → conteneur api. En plus des routes métier préfixées /api/*, l'API sert
	# aussi des routes à la racine : /auth/* (session), /health (sonde) et
	# /webhooks/* (SumUp/Zettle/HelloAsso, signés HMAC). Sans ce routage, ces
	# chemins tombaient sur le fallback SPA ci-dessous → login et webhooks cassés
	# en prod derrière Caddy (#215).
	@api path /api/* /auth/* /health /webhooks/*
	handle @api {
		reverse_proxy api:{$API_PORT}
	}

	# Front SPA : fichiers statiques buildés, fallback SPA sur index.html.
	# La livraison réelle des assets (volume/image web) est finalisée en M0-08.
	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
	}
}
