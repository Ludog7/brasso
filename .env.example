# Copier en `.env` puis renseigner. `.env` est gitignoré : aucun secret réel commité.
# Les secrets ne vivent qu'en variables d'environnement (SPEC-ORCHESTRATION §6).

# ── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_USER=brasso
POSTGRES_PASSWORD=change-me-en-prod
POSTGRES_DB=brasso
# Port exposé sur l'hôte en dev (docker-compose.dev.yml)
POSTGRES_PORT=5432

# ── Base de données (URL construite depuis les variables ci-dessus) ───────
# En conteneur (prod), l'hôte est le nom de service `postgres`.
# En dev avec l'API lancée sur l'hôte, remplacer `postgres` par `localhost`.
DATABASE_URL=postgresql://brasso:change-me-en-prod@postgres:5432/brasso?schema=public

# ── API ───────────────────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=3000
# Secret de session / cookies (Argon2, M0-06). Générer : `openssl rand -hex 32`
SESSION_SECRET=change-me-generer-un-secret-aleatoire-fort

# ── Seed (développement uniquement) ───────────────────────────────────────
# Compte admin amorcé par `pnpm --filter @brasso/db db:seed` (M1-02). Optionnel :
# sans ces variables, le seed peuple tout SAUF le compte admin. Ne jamais
# committer de mot de passe réel — ces valeurs vivent en variables d'env.
SEED_ADMIN_EMAIL=admin@brasso.local
SEED_ADMIN_PASSWORD=change-me-en-dev
SEED_ADMIN_NAME=Admin Dev

# ── Caddy (prod : TLS automatique) ────────────────────────────────────────
# Domaine public servi et email ACME pour Let's Encrypt.
DOMAIN=brasso.example.org
ACME_EMAIL=admin@example.org
