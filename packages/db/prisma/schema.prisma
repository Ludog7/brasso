// Schéma Prisma complet de Brasso — modèle de données §3 (SPEC-ORCHESTRATION),
// détail des champs d'après SPEC-FONCTIONNELLE. Structuré par ADR-06/07/09.
//
// Conventions (CLAUDE.md) :
//   - IDs `cuid`, timestamps `createdAt` / `updatedAt`.
//   - Unités internes : gramme (g), litre (L), °C, SG brute (1.052), EBC,
//     acides alpha en fraction (0.062), bar. Quantités physiques = Float.
//   - Monnaie et taux : entiers (centimes, ppm) — jamais de flottant.
//   - Aucune constante métier hardcodée (ADR-01) : tout paramètre vit en base
//     (Settings, profils) ou dans le catalogue.
//   - Append-only : StockMovement, ExternalTransaction, AuditLog n'ont pas
//     d'`updatedAt` et sont verrouillés par trigger (voir migration).
//   - Ne JAMAIS modifier une migration mergée → nouvelle migration additive.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

/// Moteur de calcul d'une recette (ADR-06) : détermine la table de détail et le
/// moteur `core` (M1-12).
enum RecipeEngine {
  BEER
  ALT_FERMENTED
  SOFT_DRINK
}

/// Cycle de vie d'une recette (ADR-06). `PUBLISHED` est immuable.
enum RecipeStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// Catégorie d'ingrédient — base de la polymorphie `RecipeIngredient` (§3.3).
enum IngredientCategory {
  MALT
  SUGAR
  HOP
  YEAST
  ADJUNCT
}

/// Moment d'emploi d'un ingrédient (règles IBU par `use`, M1-06).
enum IngredientUse {
  MASH
  FIRST_WORT
  BOIL
  WHIRLPOOL
  DRY_HOP
  PRIMARY
  SECONDARY
  BOTTLING
  OTHER
}

/// Type d'étape de process d'une recette (params détaillés en JSONB).
enum ProcessStepType {
  MASH
  MASH_STEP
  SPARGE
  BOIL
  WHIRLPOOL
  COOL
  FERMENT
  STABILIZE
  CONDITION
  PACKAGE
  OTHER
}

/// Méthode de stabilisation (moteurs ALT/SOFT, sécurité microbio §ADR-11).
/// Obligatoire pour publier une recette ALT (validé par core, M1-12).
enum StabilizationMethod {
  PASTEURIZATION
  THERMAL
  COLD_CHAIN
  FILTRATION_ACIDIFICATION
  CHEMICAL
  OTHER
}

/// Statut d'un batch (ADR-07, §3.2).
enum BatchStatus {
  PLANIFIE
  EN_BRASSAGE
  EN_FERMENTATION
  EN_CONDITIONNEMENT
  TERMINE
  ANNULE
}

/// Nature d'une mesure relevée sur un batch.
enum MeasureType {
  GRAVITY
  TEMPERATURE
  PH
  VOLUME
  OTHER
}

/// Phases de la state machine Jour J (§ spec fonctionnelle, détail core M1-13).
/// Correspondance avec les `Phase` core (M4-01 `phaseToDayPhase`) :
/// INITIALIZATION↔INITIALISATION, MASH↔EMPATAGE, LAUTER↔FILTRATION,
/// BOIL↔EBULLITION, COOLING↔REFROIDISSEMENT, PITCHING↔ENSEMENCEMENT ; brassin
/// terminé (curseur hors plan) ↔ TERMINE.
enum DayPhase {
  INITIALISATION
  EMPATAGE
  FILTRATION
  EBULLITION
  WHIRLPOOL
  REFROIDISSEMENT
  ENSEMENCEMENT
  TERMINE
}

/// Phase du cycle **post-ensemencement** d'un brassin (M9, FORMULES §13.1).
/// Distinct de `DayPhase` : le Jour J s'arrête à l'ensemencement, ces phases-ci
/// courent sur plusieurs semaines. `DRY_HOP` est **conditionnelle** — elle
/// n'existe que si la recette porte un houblon en `use = DRY_HOP`.
enum BatchMilestoneKind {
  FERMENTATION
  DRY_HOP
  COLD_CRASH
  GARDE
}

/// Mise en condition d'une ligne de conditionnement avant mise en vente (M9-15).
/// Une bière tout juste conditionnée est plate : il lui faut ses bulles.
/// - `REFERMENTATION` — bouteille : la levure résiduelle consomme le sucre de
///   priming et carbonate en bouteille (FORMULES §8.1). Compter ~3 semaines.
/// - `FORCED_CARBONATION` — fût : le CO₂ est poussé au détendeur, sans
///   refermentation (§8.2). Prête ~1 semaine après un relevé de pression
///   conforme à la cible.
/// - `NONE` — aucune mise en condition déclarée.
enum ConditioningMethod {
  NONE
  REFERMENTATION
  FORCED_CARBONATION
}

/// Type de correction densité/volume pré-ébullition proposée puis journalisée
/// (M4-02/M4-07). Valeurs indicatives d'aide à la décision (ADR-11).
enum CorrectionType {
  EXTEND_BOIL
  ADD_SUGAR
  DILUTE
  OTHER
}

/// Logique de stock d'un article de catalogue (§3.3).
/// `PRODUIT_FINI` (M9) : boisson conditionnée, issue d'un brassin. Alimenté par
/// le conditionnement (M9-08) via un `StockMovement(reason: PRODUCTION)` et
/// **décrémenté par les ventes** grâce au pipeline hub caisse existant (M7),
/// sans code nouveau : `SkuMapping` et `DisplayScreenItem` référencent déjà
/// `CatalogItem`. Cf. SPEC-ORCHESTRATION §9.2 (Q10).
enum CatalogKind {
  RECETTE
  BULK
  CONDITIONNEMENT
  PRODUIT_FINI
}

/// Unité de stock d'un article. Unités internes g/L ; `UNIT` pour le comptable
/// (bouteilles, capsules, fûts…).
enum StockUnit {
  GRAM
  LITER
  UNIT
}

/// Motif d'un mouvement de stock (registre append-only).
enum StockMovementReason {
  PURCHASE
  PRODUCTION
  ADJUSTMENT
  INVENTORY
  SALE
  LOSS
  RETURN
  OTHER
}

/// Cycle de vie d'une réservation de stock (§3.3).
enum ReservationStatus {
  RESERVED
  CONSUMED
  RELEASED
}

/// Fournisseur externe branché au hub (ADR-09).
enum ExternalProviderKind {
  HELLOASSO
  SUMUP
  ZETTLE
}

/// Nature normalisée d'une transaction externe.
enum ExternalTransactionKind {
  SALE
  MEMBERSHIP
  DONATION
  OTHER
}

/// Statut de rapprochement d'une transaction externe (mode dégradé §3.6).
enum ExternalTransactionStatus {
  MAPPED
  UNMAPPED
  IGNORED
}

/// Type d'anomalie d'intégration (dashboard anomalies §3.6).
enum IntegrationAlertType {
  UNMAPPED_TRANSACTION
  WEBHOOK_FAILURE
  OTHER
}

/// Statut d'une anomalie d'intégration.
enum IntegrationAlertStatus {
  OPEN
  RESOLVED
}

/// Statut de cotisation d'un membre (§3.4).
enum MembershipStatus {
  A_JOUR
  EN_RETARD
}

/// Type de consentement RGPD (historisé, §3.4).
enum ConsentType {
  COMMUNICATION
  PHOTOS
  NOTIFICATIONS_LEGALES
}

/// Fonction associative d'un membre (distincte des rôles RBAC applicatifs §3.5).
enum AssociativeRole {
  ADHERENT
  BRASSEUR
  CA
  TRESORIER
  REFERENT_RGPD
}

// ─────────────────────────────────────────────────────────────────────────────
// Configuration
// ─────────────────────────────────────────────────────────────────────────────

/// Configuration mono-tenant de l'instance (ADR-01 : aucune constante métier
/// hardcodée hors de cette table). Prévue en ligne unique, extensible au fil
/// des besoins (profils d'eau, TVA, fuseau, nom de l'asso…).
model Settings {
  id String @id @default(cuid())

  /// Nom de l'association / microbrasserie.
  assoName String

  /// Taux de TVA en parties par million (ppm) — ex. 20 % = 200000 ppm.
  /// Unité entière conforme à la règle « pas de flottant pour la monnaie/taux ».
  tvaRatePpm Int @default(0)

  /// Profil d'eau par défaut (JSONB) : concentrations ioniques (Ca, Mg, HCO3…),
  /// structure détaillée définie côté `core` en M1.
  defaultWaterProfile Json?

  /// Fuseau horaire de l'instance (IANA), défaut France métropolitaine.
  timezone String @default("Europe/Paris")

  /// Durée de validité d'une cotisation, en **jours** (entier, jamais de flottant).
  /// Le statut d'adhésion se dérive de cette période + `Member.lastContributionAt`
  /// (M6 ; ADR-01 : aucune constante métier hardcodée hors de cette table).
  membershipPeriodDays Int @default(365)

  /// Durées **par défaut** du cycle post-ensemencement, en **jours** entiers
  /// (M9, FORMULES §13.1). ADR-01 : ce sont des paramètres métier, jamais des
  /// constantes de `core` — elles sont lues ici puis **fournies en entrée** au
  /// calcul des jalons. Ajustables par brassin à la validation de l'ensemencement.
  defaultFermentationDays Int @default(14)
  defaultDryHopDays       Int @default(3)
  defaultColdCrashDays    Int @default(2)
  defaultConditioningDays Int @default(21)

  /// Délais de **mise en condition** avant mise en vente, en **jours** entiers
  /// (M9-15). Une bière tout juste conditionnée n'est pas buvable : il lui
  /// manque ses bulles.
  /// - refermentation en bouteille : la levure carbonate sur ~3 semaines ;
  /// - carbonatation forcée en fût : ~1 semaine après un relevé de pression
  ///   conforme à la cible.
  /// ADR-01 : paramètres métier, jamais des constantes de `core`.
  refermentationDays    Int @default(21)
  forcedCarbonationDays Int @default(7)

  /// Tolérance admise (bar) entre la pression relevée au fût et la pression
  /// cible recalculée à la température relevée (M9-15, FORMULES §8.2).
  /// Stockée en **millibar** entier : la règle « pas de flottant pour un
  /// paramètre de réglage » évite qu'un 0,2 devienne 0,19999999999999998.
  carbonationToleranceMbar Int @default(200)

  /// Délai, en **minutes** avant le hors-flamme, auquel se déclenche l'étape
  /// d'assainissement du circuit de refroidissement (M9-03). Paramètre et non
  /// constante : il dépend de l'installation. ADR-11 — cette étape est un
  /// **indicateur d'aide à la décision**, jamais une garantie de stérilité.
  coolingCircuitSanitizeLeadMin Int @default(5)

  // ── Apparence / identité (M10-04, ADR-14) ──────────────────────────────────

  /// Couleur de marque, en hexadécimal **`#RRGGBB` majuscule** (ex. `#2E7D32`).
  /// `null` = pas encore configurée : l'instance retombe sur ses jetons par
  /// défaut. ADR-14 fixe la **dérivation** (OKLCH, contraste WCAG 2.1, seuils
  /// 4,5:1 et 3:1) ; elle est calculée à l'affichage, **jamais stockée** — une
  /// couleur dérivée figée en base se désynchroniserait du jour où les jetons
  /// de fond changent.
  brandColor String?

  /// **Chemin** du logo sur le volume local, relatif au répertoire de médias —
  /// jamais l'image elle-même (§9.2 Q8, comme la photo de membre). Un blob en
  /// base gonfle chaque sauvegarde logique et complique la restauration.
  /// Bornes appliquées à l'**upload** (M10-05), pas au schéma car ce sont des
  /// paramètres et non de l'état : formats `image/png`, `image/jpeg`,
  /// `image/svg+xml` ; taille maximale **1 Mio**.
  logoPath String?

  /// Thème par défaut : **aucune colonne, volontairement.** ADR-14 §5 tranche
  /// que la préférence de thème est **par poste** (stockage local, appliquée au
  /// premier rendu sans attendre le serveur — ADR-08, pas de flash hors ligne)
  /// et que le défaut « clair » est **en dur**. Une colonne ici serait un
  /// troisième concept sans porteur.

  // ── Services externes (M10-04, §9.2 Q6) ───────────────────────────────────

  /// Météo (Open-Meteo). Désactivée ou injoignable → la tuile est **masquée**,
  /// jamais d'attente bloquante (offline-first, ADR-08).
  weatherEnabled Boolean @default(false)

  /// Coordonnées de l'instance en **micro-degrés** entiers (degré × 1 000 000).
  /// Entier et non flottant, comme `tvaRatePpm` ou `carbonationToleranceMbar` :
  /// un réglage ne doit pas dériver à la sérialisation. Précision ≈ 0,1 m,
  /// très au-delà du besoin météo. Bornes **posées en base** par contrainte
  /// `CHECK` (latitude ±90 000 000, longitude ±180 000 000) : une coordonnée
  /// hors domaine est une donnée fausse, pas une préférence.
  weatherLatitudeMicroDeg  Int?
  weatherLongitudeMicroDeg Int?

  // ── Templates (M10-04, §9.2 Q11) ──────────────────────────────────────────

  /// Gabarit appliqué par défaut aux **nouveaux** écrans d'affichage. Réutilise
  /// l'enum `DisplayTemplate` existant (M7-02) : la demande est de l'injection
  /// de marque, **pas** une nouvelle famille de gabarits — aucun enum créé.
  /// Les écrans déjà configurés gardent le leur.
  defaultDisplayTemplate DisplayTemplate @default(CARDS)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// Identité, RBAC, RGPD
// ─────────────────────────────────────────────────────────────────────────────

/// Compte utilisateur (M0-06). Peut être lié — ou non — à un `Member` (§3.4) ;
/// les données techniques (batchs, stocks) ne référencent QUE `User.id`, jamais
/// l'identité personnelle du `Member` (séparation stricte). `passwordHash` =
/// Argon2id, jamais le clair.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // ── Bascule d'utilisateur par PIN (M10-04, ADR-13) ────────────────────────

  /// PIN de bascule sur poste partagé — **Argon2id**, mêmes paramètres que
  /// `passwordHash`, jamais le clair. `null` = **pas de PIN**, et c'est un état
  /// de premier ordre : le compte n'apparaît alors pas au sélecteur et se
  /// connecte par mot de passe. Jamais de chaîne vide pour dire « pas de PIN ».
  ///
  /// La **longueur** (4 chiffres, 6 pour `admin`) n'est **pas** stockée : elle
  /// se vérifie à la pose, côté service. Un hash Argon2id ne révèle de toute
  /// façon pas la longueur du secret — d'où `pinRenewalRequired` ci-dessous.
  pinHash      String?
  pinUpdatedAt DateTime?

  /// Renouvellement imposé avant tout accès (ADR-13 §5). Posé quand le compte
  /// **reçoit le rôle `admin`** en portant un PIN à 4 chiffres : le PIN court
  /// est accepté une **dernière** fois pour s'authentifier, puis un écran
  /// bloquant exige un PIN à 6 chiffres avant que la session ne s'ouvre.
  /// Ce booléen est nécessaire précisément parce que le hash ne dit pas la
  /// longueur : sans lui, la règle serait invérifiable — et stocker la longueur
  /// reviendrait à stocker une information sur le secret.
  pinRenewalRequired Boolean @default(false)

  /// État de verrouillage du PIN (ADR-13 §3). **Colonnes d'état uniquement** :
  /// le seuil (5), la fenêtre (15 min), les paliers (5 → 30 min) et la remise à
  /// zéro (60 min) sont des **paramètres de politique**, ils vivent dans le
  /// code du service — jamais en base.
  pinFailedAttempts Int       @default(0)
  pinFirstFailedAt  DateTime?
  pinLockedUntil    DateTime?

  /// Lien optionnel vers le membre correspondant (compte ↔ personne).
  memberId String? @unique
  member   Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  sessions       Session[]
  roles          UserRole[]
  brewingBatches BatchBrewer[]
  measures       BatchMeasure[]
  deviationLogs  DeviationLog[]
  correctionLogs BatchCorrectionLog[]
  stockMovements StockMovement[]
  inventories    StockReservation[]
  auditLogs      AuditLog[]
  packagings     BatchPackaging[]
}

/// Méthode par laquelle une session a été ouverte (M10-04, ADR-13 §6). On
/// introduit une preuve d'identité volontairement plus faible que le mot de
/// passe : il faut pouvoir la **distinguer après coup**, sinon une action tracée
/// ne dit plus avec quel niveau de preuve son auteur a été authentifié.
enum AuthMethod {
  PASSWORD
  PIN
}

/// Session serveur persistée (ADR-10 : cookie + session en DB). Le token brut
/// n'est jamais stocké — seul son hash SHA-256 l'est ; le cookie porte le token.
model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  /// Méthode d'ouverture (ADR-13 §6), reportée au journal d'audit. Défaut
  /// `PASSWORD` : les sessions **existantes** au moment de la migration ont
  /// toutes été ouvertes par mot de passe, le défaut est donc exact et non un
  /// simple remplissage.
  ///
  /// La **durée** de la session dépend de cette méthode — 12 h par PIN contre
  /// 7 jours par mot de passe (ADR-13 §4) — mais elle reste portée par
  /// `expiresAt` : c'est le service qui calcule, la base qui constate.
  authMethod AuthMethod @default(PASSWORD)

  @@index([userId])
}

/// Rôle RBAC (matrice §3.5, figée V1 : admin, brasseur, caisse, rgpd). Table de
/// référence, seedée par migration. La matrice des permissions vit dans le code
/// (`apps/api/src/rbac/matrix.ts`) ; cette table ne porte que l'appartenance.
model Role {
  id        String     @id @default(cuid())
  key       String     @unique
  label     String
  createdAt DateTime   @default(now())
  users     UserRole[]
}

/// Affectation d'un rôle à un utilisateur (jointure N–N). Droits effectifs =
/// union des rôles.
model UserRole {
  userId    String
  roleId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, roleId])
  @@index([roleId])
}

/// Membre de l'association (donnée personnelle, §3.4). Séparé des données
/// techniques ; la pseudonymisation post-délai légal (M6-08) remplace l'identité
/// en conservant les agrégats comptables.
model Member {
  id           String            @id @default(cuid())
  memberNumber String            @unique
  firstName    String
  lastName     String
  email        String?
  phone        String?
  address      String?
  birthDate    DateTime?
  membership   MembershipStatus  @default(EN_RETARD)
  roles        AssociativeRole[] @default([])

  /// Horodatage de la **dernière cotisation rapprochée** (`occurredAt` de la
  /// transaction `MEMBERSHIP`, posé par le rapprochement M6). `null` = aucune
  /// cotisation connue → `EN_RETARD`. Source de vérité du statut, avec la période
  /// `Settings.membershipPeriodDays` (statut dérivé, `membership` = cache).
  lastContributionAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User?
  consents MemberConsent[]

  @@index([lastName])
}

/// Consentement RGPD historisé (§3.4) : append-only, une ligne par changement.
/// Le consentement courant est la ligne la plus récente pour `(memberId, type)`.
model MemberConsent {
  id        String      @id @default(cuid())
  memberId  String
  member    Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  type      ConsentType
  granted   Boolean
  createdAt DateTime    @default(now())

  @@index([memberId, type])
}

/// Journal d'audit append-only (§3.4) : accès aux données personnelles et
/// actions sensibles. Verrouillé contre UPDATE/DELETE (trigger, voir migration).
model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: NoAction)
  action       String
  resourceType String
  resourceId   String?
  /// Membre concerné quand l'action porte sur une donnée personnelle (RGPD).
  /// Champ scalaire volontaire (pas de FK) : l'audit survit à l'anonymisation.
  memberId     String?
  ip           String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([memberId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Recettes polymorphes (ADR-06, §3.1)
// ─────────────────────────────────────────────────────────────────────────────

/// Modèle théorique d'une boisson. Commun aux 3 moteurs ; le détail spécifique
/// vit dans une table 1-1 (`RecipeBeerDetails` / `RecipeAltDetails` /
/// `RecipeSoftDetails`). Versioning : `familyId` regroupe les versions ;
/// `(familyId, version)` unique ; une recette `PUBLISHED` est immuable.
model Recipe {
  id       String       @id @default(cuid())
  /// Regroupe les versions d'une même recette (ADR-06).
  familyId String
  version  Int          @default(1)
  name     String
  engine   RecipeEngine
  status   RecipeStatus @default(DRAFT)
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  beerDetails RecipeBeerDetails?
  altDetails  RecipeAltDetails?
  softDetails RecipeSoftDetails?
  ingredients RecipeIngredient[]
  steps       RecipeProcessStep[]
  batches     Batch[]

  @@unique([familyId, version])
  @@index([engine, status])
}

/// Détail moteur BEER (§3.1) : cibles densité/couleur/amertume, style BJCP.
model RecipeBeerDetails {
  recipeId     String  @id
  recipe       Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  styleBjcp    String?
  targetOg     Float?
  targetFg     Float?
  targetIbu    Float?
  targetEbc    Float?
  boilTimeMin  Int?
  /// Rendement de brassage attendu (fraction 0–1).
  efficiency   Float?
  batchVolumeL Float?
}

/// Détail moteur ALT_FERMENTED (ginger beer, hydromel, kombucha…). `baseType`
/// = taxonomie interne configurable (ADR-01, pas d'enum figé). `stabilizationMethod`
/// obligatoire pour publier (règle core M1-12).
model RecipeAltDetails {
  recipeId            String               @id
  recipe              Recipe               @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  baseType            String
  targetPh            Float?
  stabilizationMethod StabilizationMethod?
  /// Risque de sucre résiduel / carbonatation (indicateur, ADR-11).
  residualSugarRisk   Boolean              @default(false)
  batchVolumeL        Float?
}

/// Détail moteur SOFT_DRINK (limonades, boissons sucrées sans alcool).
model RecipeSoftDetails {
  recipeId            String               @id
  recipe              Recipe               @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  /// Concentration en sucre (g/L).
  sugarConcentration  Float?
  targetPh            Float?
  /// Mode de stockage : froid / ambiant (indicateur sécurité, ADR-11).
  storageMode         String?
  stabilizationMethod StabilizationMethod?
  batchVolumeL        Float?
}

/// Ingrédient d'une recette (polymorphe par catégorie). Référence un
/// `CatalogItem` quand il existe ; sinon ad-hoc via `name`. `params` porte le
/// détail spécifique (ex. AA figés pour un houblon, forme…).
model RecipeIngredient {
  id            String             @id @default(cuid())
  recipeId      String
  recipe        Recipe             @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  catalogItemId String?
  catalogItem   CatalogItem?       @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
  name          String
  category      IngredientCategory
  use           IngredientUse?
  amount        Float
  unit          StockUnit          @default(GRAM)
  /// Minute d'ajout (houblons : temps d'ébullition restant), si pertinent.
  timeMinutes   Int?
  params        Json?
  sortOrder     Int                @default(0)

  @@index([recipeId])
  @@index([catalogItemId])
}

/// Étape ordonnée du process d'une recette (empâtage, ébullition, fermentation,
/// stabilisation…). `params` JSONB : paliers, températures, durées, cibles.
model RecipeProcessStep {
  id        String          @id @default(cuid())
  recipeId  String
  recipe    Recipe          @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  type      ProcessStepType
  name      String?
  params    Json?
  sortOrder Int             @default(0)

  @@index([recipeId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Équipement
// ─────────────────────────────────────────────────────────────────────────────

/// Profil d'équipement (§3.2, moteur thermique M1-08). Toutes les pertes et
/// paramètres physiques nécessaires aux calculs d'eau et de strike.
model EquipmentProfile {
  id                      String   @id @default(cuid())
  name                    String
  nominalVolumeL          Float
  deadspaceL              Float    @default(0)
  transferLossL           Float    @default(0)
  evaporationRateLPerHour Float    @default(0)
  /// Absorption d'eau par le grain (L/kg).
  grainAbsorptionLPerKg   Float    @default(0)
  /// Puissance de chauffe (kW), pour l'estimation des rampes (Jour J).
  heatingPowerKw          Float?
  /// Masse thermique de la cuve (kJ/°C), estimation temps de montée.
  thermalMassKjPerC       Float?
  /// Profils d'eau (base réseau + cibles par style), structure définie côté core.
  waterProfiles           Json?
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  batches Batch[]
}

// ─────────────────────────────────────────────────────────────────────────────
// Batch (ADR-07, §3.2)
// ─────────────────────────────────────────────────────────────────────────────

/// Instance d'exécution datée d'une recette (ADR-07). Fige `recipeSnapshot`
/// (JSONB) au moment de la planification : le batch reste stable même si la
/// recette évolue. `batchNumber` = séquence lisible.
model Batch {
  id                 String            @id @default(cuid())
  batchNumber        Int               @unique @default(autoincrement())
  recipeId           String
  recipe             Recipe            @relation(fields: [recipeId], references: [id], onDelete: Restrict)
  recipeVersion      Int
  recipeSnapshot     Json
  equipmentProfileId String?
  equipmentProfile   EquipmentProfile? @relation(fields: [equipmentProfileId], references: [id], onDelete: SetNull)
  status             BatchStatus       @default(PLANIFIE)

  plannedAt   DateTime?
  brewedAt    DateTime?
  fermentedAt DateTime?
  packagedAt  DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brewers          BatchBrewer[]
  measures         BatchMeasure[]
  deviationLogs    DeviationLog[]
  correctionLogs   BatchCorrectionLog[]
  dayEventLogs     DayEventLog[]
  dayState         BatchDayState?
  movements        StockMovement[]
  reservations     StockReservation[]
  milestones       BatchMilestone[]
  packagings       BatchPackaging[]
  /// Articles de catalogue `PRODUIT_FINI` issus de ce brassin (M9).
  finishedProducts CatalogItem[]

  @@index([recipeId])
  @@index([status])
}

/// Jalon daté du cycle **post-ensemencement** d'un brassin (M9, FORMULES §13.1).
/// Les dates prévues sont calculées par `core` (`buildBatchMilestones`) depuis la
/// date d'ensemencement et les durées saisies ; les dates **réelles** sont
/// renseignées au fil de l'eau. Un jalon achevé (`actualEndAt` non nul) n'est
/// jamais réécrit par un changement de prévision (M9-07).
model BatchMilestone {
  id      String             @id @default(cuid())
  batchId String
  batch   Batch              @relation(fields: [batchId], references: [id], onDelete: Cascade)
  kind    BatchMilestoneKind

  /// Durée prévue, en **jours** entiers, bornée [0, 365] (validation `core`).
  /// Une durée nulle **supprime** la phase : elle ne produit pas de jalon.
  plannedDurationDays Int
  plannedStartAt      DateTime
  plannedEndAt        DateTime
  actualStartAt       DateTime?
  actualEndAt         DateTime?

  /// Rang dans la séquence FERMENTATION → DRY_HOP → COLD_CRASH → GARDE.
  sortOrder Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([batchId, kind])
  @@index([batchId])
  /// Sert les échéances de la vue Brassins (M9-09) et la tuile du tableau de bord (M13).
  @@index([plannedEndAt])
}

/// Ligne de conditionnement d'un brassin (M9, FORMULES §13.3) : « ce brassin a
/// produit N contenants de X litres ». Répond à la traçabilité « quel brassin
/// est dans ces bouteilles ». Le stock, lui, est porté par le `StockMovement`
/// append-only écrit dans la même transaction (M9-08) — cette table est le
/// détail par contenant, pas le registre de stock.
model BatchPackaging {
  id      String @id @default(cuid())
  batchId String
  batch   Batch  @relation(fields: [batchId], references: [id], onDelete: Cascade)

  /// Article `PRODUIT_FINI` créé ou incrémenté par ce conditionnement.
  catalogItemId String
  catalogItem   CatalogItem @relation("PackagedProduct", fields: [catalogItemId], references: [id], onDelete: Restrict)

  /// Article `CONDITIONNEMENT` consommé (bouteille, fût…). Nullable : un
  /// conditionnement peut être enregistré sans que le contenant soit suivi en stock.
  containerItemId String?
  containerItem   CatalogItem? @relation("PackagingContainer", fields: [containerItemId], references: [id], onDelete: SetNull)

  /// Contenance unitaire en **litres** (unité interne, jamais en centilitres).
  /// Figée ici plutôt que lue du catalogue : elle doit rester celle du jour du
  /// conditionnement même si l'article de catalogue évolue ensuite.
  containerVolumeL Float
  /// Nombre de contenants produits (entier — on ne conditionne pas 2,5 bouteilles).
  quantity         Int

  /// Mise en condition de **cette ligne** (M9-15). Elle est par contenant et non
  /// par brassin : un même brassin part souvent moitié en fûts, moitié en
  /// bouteilles, et les deux ne sont pas prêts à la vente en même temps.
  conditioningMethod ConditioningMethod @default(NONE)

  /// Carbonatation forcée (fût) : CO₂ visé en **volumes** (FORMULES §8.3), puis
  /// relevé de l'opérateur — pression en **bar** (unité interne) et température
  /// en °C. La conformité se juge contre la cible recalculée à la température
  /// **relevée**, pas à celle prévue.
  co2TargetVolumes    Float?
  measuredPressureBar Float?
  measuredTempC       Float?
  /// Instant du relevé jugé conforme ; nul tant qu'aucun relevé ne l'est.
  carbonationValidatedAt DateTime?

  /// Date **estimée** de mise en vente (ADR-11 : indicateur d'aide à la
  /// décision, jamais une garantie). Nulle tant que la mise en condition n'est
  /// pas engagée — une bière sans bulles n'est pas vendable.
  availableForSaleAt DateTime?

  packagedAt   DateTime @default(now())
  packagedById String?
  packagedBy   User?    @relation(fields: [packagedById], references: [id], onDelete: SetNull)
  note         String?

  @@index([batchId])
  @@index([catalogItemId])
}

/// Brasseur(s) responsable(s) d'un batch (jointure N–N).
model BatchBrewer {
  batchId   String
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([batchId, userId])
  @@index([userId])
}

/// Mesure réelle relevée sur un batch (append-only). `phase` = phase Jour J ou
/// de fermentation ; `loggedBy` = utilisateur.
/// M9 — les **prises de volume** aux étapes clés (pré-ébullition, post-ébullition,
/// ensemencement, conditionné) n'appellent **aucune structure nouvelle** :
/// `MeasureType.VOLUME` existe déjà et `phase` qualifie l'étape. La chaîne des
/// volumes (FORMULES §13.2) se dérive de ces lignes.
model BatchMeasure {
  id         String      @id @default(cuid())
  batchId    String
  batch      Batch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  type       MeasureType
  value      Float
  unit       String?
  phase      String?
  loggedById String?
  loggedBy   User?       @relation(fields: [loggedById], references: [id], onDelete: SetNull)
  loggedAt   DateTime    @default(now())

  @@index([batchId, type])
}

/// Journal d'écart de procédure (§3.2) : créé par « Forcer l'étape » en mode
/// manuel. Append-only. `phase`/`forcedFromStatus`/`occurredAt` proviennent de
/// l'intention `DeviationLog` core (M1-13) ; nullables pour rétrocompat (M4-03).
model DeviationLog {
  id               String    @id @default(cuid())
  batchId          String
  batch            Batch     @relation(fields: [batchId], references: [id], onDelete: Cascade)
  step             String
  /// Phase Jour J au moment du forçage (mapping core, M4-01 `phaseToDayPhase`).
  phase            DayPhase?
  /// Statut de l'étape (StepStatus core) au moment du forçage.
  forcedFromStatus String?
  reason           String
  authorId         String?
  author           User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  /// Horodatage métier du forçage (`event.at`), distinct de `createdAt` (insertion).
  occurredAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())

  @@index([batchId])
}

/// État courant de la state machine Jour J (1-1 batch). Le détail (transitions,
/// timers) est calculé par core (M1-13) ; la DB porte l'instantané reprenable.
model BatchDayState {
  batchId   String   @id
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  phase     DayPhase @default(INITIALISATION)
  /// Timers, horodatages et statut par étape (JSONB, forme définie par core).
  state     Json?
  /// Compteur monotone incrémenté à chaque transition appliquée — détection de
  /// rejeu périmé côté sync offline (M4-06).
  revision  Int      @default(0)
  updatedAt DateTime @updatedAt
}

/// Journal des décisions de correction densité/volume pré-ébullition (§ spec
/// « Journalisation des décisions ») — append-only. `payload` conserve la
/// proposition retenue et les valeurs projetées (OG/ABV), calculées par core
/// (M4-02). Indicateur d'aide à la décision (ADR-11), jamais une garantie.
model BatchCorrectionLog {
  id        String         @id @default(cuid())
  batchId   String
  batch     Batch          @relation(fields: [batchId], references: [id], onDelete: Cascade)
  stepId    String
  type      CorrectionType
  payload   Json
  authorId  String?
  author    User?          @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt DateTime       @default(now())

  @@index([batchId])
}

/// Idempotence du rejeu de la file d'événements offline (ADR-08, M4-06). `id` =
/// `clientEventId` fourni par le client : rejouer deux fois le même événement est
/// un no-op. `resultRevision` = `BatchDayState.revision` après application ;
/// `rejected`/`rejection` tracent un événement refusé par `transition`.
model DayEventLog {
  id             String   @id
  batchId        String
  batch          Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  type           String
  appliedAt      DateTime @default(now())
  resultRevision Int
  rejected       Boolean  @default(false)
  rejection      String?

  @@index([batchId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Catalogue & stock (§3.3)
// ─────────────────────────────────────────────────────────────────────────────

/// Article de catalogue (ingrédient, bulk, conditionnement). `kind` détermine la
/// logique de stock ; `category` (pour les articles RECETTE) porte la catégorie
/// d'ingrédient. `attributes` JSONB : détail spécifique (couleur EBC des malts,
/// acides alpha des houblons, atténuation des levures…), validé par core/Zod.
model CatalogItem {
  id                   String              @id @default(cuid())
  name                 String
  kind                 CatalogKind
  category             IngredientCategory?
  unit                 StockUnit           @default(GRAM)
  attributes           Json?
  /// Coût unitaire de référence (centimes), pour l'estimation du coût de revient.
  defaultUnitCostCents Int?
  /// Seuil d'alerte de stock bas (dans l'unité de l'article).
  reorderThreshold     Float?
  isActive             Boolean             @default(true)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  /// Pour un `PRODUIT_FINI` (M9) : brassin d'origine. Nul pour toute autre
  /// famille. L'unité de stock est le **brassin**, pas la recette — deux brassins
  /// d'une même recette donnent deux articles distincts, sans quoi la traçabilité
  /// de lot (rappel, DLU, écart qualité) serait perdue.
  sourceBatchId String?
  sourceBatch   Batch?  @relation(fields: [sourceBatchId], references: [id], onDelete: SetNull)

  lots              StockLot[]
  movements         StockMovement[]
  reservations      StockReservation[]
  recipeIngredients RecipeIngredient[]
  skuMappings       SkuMapping[]
  displayItems      DisplayScreenItem[]
  /// Conditionnements ayant produit cet article (quand il est `PRODUIT_FINI`).
  packagedAs        BatchPackaging[]    @relation("PackagedProduct")
  /// Conditionnements ayant consommé cet article comme contenant.
  usedAsContainer   BatchPackaging[]    @relation("PackagingContainer")

  @@index([kind])
  @@index([category])
  @@index([sourceBatchId])
}

/// Lot physique d'un article (quantité, DLU, coût d'achat). La quantité courante
/// se dérive des mouvements ; `quantity` sert d'aide/inventaire.
model StockLot {
  id            String      @id @default(cuid())
  catalogItemId String
  catalogItem   CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Restrict)
  lotCode       String?
  quantity      Float       @default(0)
  /// Date limite d'utilisation optimale.
  bestBeforeAt  DateTime?
  /// Coût unitaire à l'achat (centimes).
  unitCostCents Int?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  movements StockMovement[]

  @@index([catalogItemId])
}

/// Registre de mouvements de stock APPEND-ONLY (§3.3). `delta` signé, dans
/// l'unité de l'article. Verrouillé contre UPDATE/DELETE (trigger, migration).
model StockMovement {
  id                    String               @id @default(cuid())
  catalogItemId         String
  catalogItem           CatalogItem          @relation(fields: [catalogItemId], references: [id], onDelete: Restrict)
  stockLotId            String?
  stockLot              StockLot?            @relation(fields: [stockLotId], references: [id], onDelete: NoAction)
  delta                 Float
  reason                StockMovementReason
  batchId               String?
  batch                 Batch?               @relation(fields: [batchId], references: [id], onDelete: NoAction)
  userId                String?
  user                  User?                @relation(fields: [userId], references: [id], onDelete: NoAction)
  /// Transaction externe à l'origine du mouvement (vente mappée, §3.6).
  externalTransactionId String?
  externalTransaction   ExternalTransaction? @relation("TransactionStockMovements", fields: [externalTransactionId], references: [id], onDelete: NoAction)
  note                  String?
  createdAt             DateTime             @default(now())

  @@index([catalogItemId])
  @@index([batchId])
  @@index([createdAt])
}

/// Réservation de stock (§3.3) : posée à la planification d'un batch (kind
/// RECETTE), consommée à l'ensemencement (ajustée au volume réel).
model StockReservation {
  id            String            @id @default(cuid())
  catalogItemId String
  catalogItem   CatalogItem       @relation(fields: [catalogItemId], references: [id], onDelete: Restrict)
  batchId       String
  batch         Batch             @relation(fields: [batchId], references: [id], onDelete: Cascade)
  quantity      Float
  status        ReservationStatus @default(RESERVED)
  createdById   String?
  createdBy     User?             @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([catalogItemId])
  @@index([batchId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Hub caisse & intégrations (ADR-09, §3.6)
// ─────────────────────────────────────────────────────────────────────────────

/// Fournisseur externe (HelloAsso / SumUp / Zettle). Les SECRETS (clé de
/// signature webhook) restent en variables d'environnement — on ne stocke ici
/// qu'une référence (`webhookSecretRef`), jamais le secret en clair (CLAUDE.md).
model ExternalProvider {
  id               String               @id @default(cuid())
  kind             ExternalProviderKind
  label            String
  config           Json?
  webhookSecretRef String?
  isActive         Boolean              @default(true)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  transactions ExternalTransaction[]
  skuMappings  SkuMapping[]
  alerts       IntegrationAlert[]

  @@unique([kind, label])
}

/// Transaction externe APPEND-ONLY (ADR-09) : payload brut conservé + champs
/// normalisés. Jamais modifiée depuis la plateforme. Verrouillée par trigger.
model ExternalTransaction {
  id                String                    @id @default(cuid())
  providerId        String
  provider          ExternalProvider          @relation(fields: [providerId], references: [id], onDelete: Restrict)
  /// Identifiant natif chez le fournisseur (idempotence des webhooks).
  externalId        String
  kind              ExternalTransactionKind   @default(OTHER)
  amountCents       Int
  currency          String                    @default("EUR")
  paymentMethod     String?
  externalProductId String?
  status            ExternalTransactionStatus @default(UNMAPPED)
  /// Membre rapproché (cotisation HelloAsso → membre), si identifié.
  memberId          String?
  occurredAt        DateTime
  rawPayload        Json
  createdAt         DateTime                  @default(now())

  alerts    IntegrationAlert[]
  movements StockMovement[]    @relation("TransactionStockMovements")

  @@unique([providerId, externalId])
  @@index([status])
  @@index([occurredAt])
}

/// Correspondance SKU interne ↔ produit externe (§3.6).
model SkuMapping {
  id                String           @id @default(cuid())
  internalSku       String           @unique
  catalogItemId     String?
  catalogItem       CatalogItem?     @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
  providerId        String
  provider          ExternalProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  externalProductId String
  externalCategory  String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([providerId, externalProductId])
  @@index([catalogItemId])
}

/// Anomalie d'intégration (transaction non mappée / webhook en échec, §3.6) →
/// dashboard anomalies, traitement manuel.
model IntegrationAlert {
  id            String                 @id @default(cuid())
  type          IntegrationAlertType
  status        IntegrationAlertStatus @default(OPEN)
  message       String
  providerId    String?
  provider      ExternalProvider?      @relation(fields: [providerId], references: [id], onDelete: SetNull)
  transactionId String?
  transaction   ExternalTransaction?   @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  createdAt     DateTime               @default(now())
  resolvedAt    DateTime?

  @@index([status])
  @@index([type])
}

// ─────────────────────────────────────────────────────────────────────────────
// Module d'affichage en brasserie (M7-02, §Module d'affichage)
// ─────────────────────────────────────────────────────────────────────────────

/// Mode de rendu d'un écran d'affichage (§Templates : liste / tableau / cartes).
/// Enum figé (choix UI), ≠ constante métier (ADR-01).
enum DisplayTemplate {
  LIST
  TABLE
  CARDS
}

/// Surface d'affichage (Bar, Salle, Événement…). Nom **libre** — aucune constante
/// métier codée en dur (ADR-01), l'association crée ses propres libellés.
model DisplaySurface {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  screens DisplayScreen[]
}

/// Écran d'une surface : template de rendu + mentions légales (**texte libre**
/// porté par l'écran — alcool/allergènes, aucune formulation réglementaire en dur).
model DisplayScreen {
  id            String          @id @default(cuid())
  surfaceId     String
  surface       DisplaySurface  @relation(fields: [surfaceId], references: [id], onDelete: Cascade)
  name          String
  template      DisplayTemplate @default(CARDS)
  legalMentions String?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  items DisplayScreenItem[]

  @@index([surfaceId])
}

/// Produit sélectionné sur un écran + ses indicateurs (« nouveau »/« coup de
/// cœur »/« brassin spécial »). `priceCents` : prix affiché optionnel (centimes).
model DisplayScreenItem {
  id            String        @id @default(cuid())
  screenId      String
  screen        DisplayScreen @relation(fields: [screenId], references: [id], onDelete: Cascade)
  catalogItemId String
  catalogItem   CatalogItem   @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  isNew         Boolean       @default(false)
  isFavorite    Boolean       @default(false)
  isSpecial     Boolean       @default(false)
  priceCents    Int?
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([screenId, catalogItemId])
  @@index([screenId])
}
